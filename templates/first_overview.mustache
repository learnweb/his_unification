{{!
    @template local_lsf_unification/first_overview

    This template renders the first overview part of the request page.

    Example (json):
    {
        "courselist": [
            {
                "title": "Veranstaltungstitel Nr.1",
            },
            {
                "title": "Veranstaltungstitel Nr.2",
            },
            {
                "title": "Veranstaltungstitel Nr.3",
            }
        ]
    }
}}
<div id="lsf_unification_courselist_root">
    <p>{{#str}} notice, local_lsf_unification {{/str}}</p>

    <form name="input" action="request.php" method="post">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">{{#str}} question, local_lsf_unification {{/str}}</h5>
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    {{! Option 1: Course found }}
                    <label class="list-group-item list-group-item-action d-flex align-items-start gap-2 py-2">
                        <input class="form-check-input mt-1" type="radio" name="answer" id="answer1" value="1">
                        <span class="flex-grow-1">
                            <strong>{{#str}} answer_course_found, local_lsf_unification {{/str}}</strong>
                            {{#courselist}}
                                <ul class="mb-0 ms-3 mt-1">
                                        <li>{{{title}}}</li>
                                </ul>
                            {{/courselist}}
                        </span>
                    </label>

                    {{! Option 2: Course in LSF but not found here }}
                    <label class="list-group-item list-group-item-action d-flex align-items-start gap-2 py-2">
                        <input class="form-check-input mt-1" type="radio" name="answer" id="answer3" value="3">
                        <span class="flex-grow-1">{{#str}} answer_course_in_lsf_and_visible, local_lsf_unification {{/str}}</span>
                    </label>

                    {{! Option 3: Remote request }}
                    {{#showremotecreation}}
                        <label class="list-group-item list-group-item-action d-flex align-items-start gap-2 py-2">
                            <input class="form-check-input mt-1" type="radio" name="answer" id="answer11" value="11">
                            <span class="flex-grow-1">{{#str}} answer_proxy_creation, local_lsf_unification {{/str}}</span>
                        </label>
                    {{/showremotecreation}}

                    {{! Option 4: Go to old request form }}
                    <label class="list-group-item list-group-item-action d-flex align-items-start gap-2 py-2">
                        <input class="form-check-input mt-1" type="radio" name="answer" id="answer6" value="6">
                        <span class="flex-grow-1">{{#str}} answer_goto_old_requestform, local_lsf_unification {{/str}}</span>
                    </label>
                </div>
            </div>
        </div>

        {{! Submit button }}
        <div class="mt-3">
            <button class="btn btn-primary" type="submit">{{#str}} select, local_lsf_unification {{/str}}</button>
        </div>
    </form>
</div>