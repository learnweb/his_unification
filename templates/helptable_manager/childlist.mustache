{{!
    @template local_lsf_unification/helptable_manager/childlist

    This template renders the Admin settings page to create/edit/delete category matching from the lsf to moodle.

    Example (json):
    {

    }
}}

<div class="container mt-3">
    {{! Breadcrumb navigation }}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            {{#parents}}
                <li class="breadcrumb-item">
                    <a href="{{{parentlink}}}">{{parenttext}}</a>
                </li>
            {{/parents}}
        </ol>
    </nav>

    <form action='' method='get'>
        <div class="card">
            <div class="card-body p-0">
                <table class="table table-hover table-sm mb-0">
                    <tbody>
                    {{#childs}}
                        <tr><td class="align-middle">
                            {{#sublevels}}
                                <a href="{{{childoriginlink}}}" class="btn btn-sm btn-outline-secondary">
                                    {{#str}} navigate, local_lsf_unification {{/str}}
                                </a>
                            {{/sublevels}}
                        </td>
                            <td class="align-middle">
                                <label for="{{idchildorigin}}" class="mb-0">{{prefixchildtxt}}</label>
                            </td>
                            <td class="align-middle">
                                {{#emptychildmdlid}}
                                    <span class="badge badge-warning">
                                        {{#str}} not_mapped, local_lsf_unification {{/str}}
                                    </span>
                                {{/emptychildmdlid}}
                                {{^emptychildmdlid}}
                                    <a href="{{{categorylink}}}">{{childname}}</a>
                                {{/emptychildmdlid}}
                            </td>
                            <td class="align-middle">
                                <div class="form-check">
                                    <input id="{{idchildorigin}}" class="form-check-input" type="checkbox" name="{{namechildorigin}}" value="x">
                                    <label class="form-check-label" for="{{idchildorigin}}">
                                        {{#emptychildmdlid}}
                                            {{#str}} map, local_lsf_unification {{/str}}
                                        {{/emptychildmdlid}}
                                        {{^emptychildmdlid}}
                                            {{#str}} overwrite, local_lsf_unification {{/str}}
                                        {{/emptychildmdlid}}
                                    </label>
                                </div>
                            </td>
                            <td class="align-middle">
                                {{^emptychildmdlid}}
                                    <a href="{{{deletelink}}}" class="btn btn-sm btn-outline-danger">
                                        {{#str}} delete, local_lsf_unification {{/str}}
                                    </a>
                                {{/emptychildmdlid}}
                            </td>
                        </tr>
                    {{/childs}}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-3 d-flex align-items-center gap-2">
            <label class="mb-0"><b>{{#str}} main_category, local_lsf_unification {{/str}}</b></label>
            <select name="mainid" class="form-select form-select-sm w-auto">
                {{#options}}
                    <option value="{{value}}">{{text}}</option>
                {{/options}}
            </select>
            <input type="submit" class="btn btn-primary btn-sm" value="{{#str}} map, local_lsf_unification {{/str}}">
            <input type="hidden" name="originid" value="{{originid}}">
            <input type="hidden" name="maxorigin" value="{{maxorigin}}">
        </div>
    </form>
</div>
